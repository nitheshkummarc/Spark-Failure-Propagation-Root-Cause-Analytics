# =============================================================================
# Spark Root-Cause Analytics — Environment Variables
# Copy this file to .env and customize for your environment.
# =============================================================================

# HDFS
HDFS_NAMENODE_URI=hdfs://namenode:8020
HDFS_BASE_PATH=/project

# Spark
SPARK_MASTER=yarn
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=3g
SPARK_EXECUTOR_CORES=2

# YARN
YARN_RESOURCEMANAGER_HOSTNAME=resourcemanager

# Docker resource allocation (adjust based on host machine)
# Recommended: 16GB+ RAM allocated to Docker Desktop
